# Google OAuth (Gmail + Calendar)
# Steps to obtain:
# 1. Go to https://console.cloud.google.com → create a new project
# 2. Enable "Gmail API" and "Google Calendar API" for your project
# 3. Go to APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# 4. Choose "Desktop app" as application type
# 5. Run: node scripts/get-gmail-token.mjs YOUR_CLIENT_ID YOUR_CLIENT_SECRET
# 6. Fill in these values:

GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_USER_EMAIL=your-email@gmail.com

# Weather (Open-Meteo — free, no API key needed)
# Defaults to Karachi if not set
WEATHER_CITY=Karachi
WEATHER_LAT=24.8607
WEATHER_LON=67.0011
